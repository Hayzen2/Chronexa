{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "vite",
  "outputDirectory": "client/dist",
  "public": false,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": [
    {
      "key": "VITE_BACKEND_URL",
      "value": "@railway_backend_url"
    }
  ],
  "regions": ["iad1"],
  "git": {
    "deploymentEnabled": true
  }
}
