# Production Environment Variables
# Copy this to your Vercel and Railway dashboards (never commit actual values)

# ============================================================================
# RAILWAY BACKEND ENVIRONMENT VARIABLES
# ============================================================================

# Core Configuration
NODE_ENV=production
BACKEND_URL=https://your-backend.up.railway.app
BACKEND_PORT=3000

# ============================================================================
# DATABASE (Auto-generated by Railway PostgreSQL service)
# ============================================================================
DATABASE_URL=postgresql://user:password@host:5432/chronexa
DB_SYNCHRONIZE=false

# ============================================================================
# AUTHENTICATION - JWT SECRETS (Generate random 32+ character strings)
# ============================================================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_REFRESH_SECRET=your_very_long_random_refresh_secret_min_32_characters
JWT_ACCESS_SECRET=your_very_long_random_access_secret_min_32_characters

# ============================================================================
# EMAIL SERVICE (Resend Email API)
# ============================================================================
# 1. Sign up at https://resend.com
# 2. Go to API Tokens section
# 3. Create new API token and copy it
RESEND_API_KEY=re_your_resend_api_key_here
MAIL_FROM=Chronexa <noreply@chronexa.com>
MAIL_REPLY_TO=support@chronexa.com

# ============================================================================
# REDIS CACHE (Auto-generated by Railway Redis service)
# ============================================================================
REDIS_URL=redis://:password@host:6379
REDIS_PORT=6379

# ============================================================================
# OBJECT STORAGE - MinIO
# ============================================================================
# Option 1: Use MinIO on Railway
OBJECT_STORAGE_ENDPOINT=your-minio.up.railway.app
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minio_secure_password_here
OBJECT_STORAGE_PORT=9000
OBJECT_STORAGE_URL=https://your-minio.up.railway.app

# Option 2: Use AWS S3 (uncomment if using S3 instead)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# S3_BUCKET=chronexa-production

# ============================================================================
# FRONTEND URL (for CORS configuration)
# ============================================================================
FRONTEND_URL=https://your-chronexa.vercel.app

# ============================================================================
# VERCEL FRONTEND ENVIRONMENT VARIABLES
# ============================================================================

# Backend API URL - Points to Railway backend
VITE_BACKEND_URL=https://your-backend.up.railway.app/api

# ============================================================================
# OPTIONAL: SENTRY ERROR TRACKING
# ============================================================================
# SENTRY_DSN=https://your_sentry_key@sentry.io/your_project_id

# ============================================================================
# OPTIONAL: ANALYTICS
# ============================================================================
# GTAG_ID=G-XXXXXXXXXXXX

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
# 
# 1. VERCEL SETUP:
#    - Go to vercel.com → Your Project → Settings → Environment Variables
#    - Add: VITE_BACKEND_URL=https://your-backend.up.railway.app/api
#
# 2. RAILWAY SETUP:
#    - Go to railway.app → Your Project → Variables
#    - Add ALL variables from this file (except VITE_BACKEND_URL)
#    - PostgreSQL and Redis connection strings are auto-generated
#
# 3. SECURITY:
#    - NEVER commit .env.production to git
#    - Always use platform dashboards (Vercel/Railway) for secrets
#    - Use strong random values for JWT_*_SECRET variables
#    - Rotate secrets periodically in production
#    - Enable secret masking in GitHub Actions
#
# 4. VERIFY DEPLOYMENT:
#    - Frontend: https://your-chronexa.vercel.app
#    - Backend Health: https://your-backend.up.railway.app/health
#    - Check logs in Vercel Deployments & Railway Logs
#
